# 構建題庫前端（Vite + React）
FROM node:20-alpine AS builder

WORKDIR /app

COPY analyzer/client-app/package*.json ./
RUN npm install

COPY analyzer/client-app ./
RUN npm run build

# 使用 Nginx 提供靜態文件
FROM nginx:alpine

# 拷貝前端構建結果
COPY --from=builder /app/dist /usr/share/nginx/html

# 自定義 Nginx 配置，支持前端路由
COPY analyzer/client-app/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
